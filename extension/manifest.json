{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "SOOP - 애드블록",
  "version": "2.5",
  "description": "숲에서 광고를 차단합니다.",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": ["*://*.sooplive.com/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "blocklist",
        "enabled": true,
        "path": "AdBlock/blockAds.json"
      }
    ]
  },
    "icons": {
    "128": "icon/icon128.png",
    "48": "icon/icon48.png",
    "16": "icon/icon16.png"
  },
  "content_scripts": [
    {
      "matches": ["*://www.sooplive.com/*"],
      "js": ["AdBlock/hideMainBanner.js"],
      "css": ["style.css"]
    },
    {
      "matches": ["*://play.sooplive.com/*"],
      "js": ["AdBlock/hideChatBanner.js"]
    },
    {
      "matches": ["*://*.sooplive.com/*"],
      "css": ["AdBlock/hideBanner.css"]
    }
  ],

  "background": {
    "service_worker": "popup.js"
  }
}